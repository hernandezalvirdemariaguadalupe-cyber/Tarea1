<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#001F3F">

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_weight="1"
        android:background="@drawable/img4" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">


        <Button
            android:id="@+id/btnTextFields"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="READ MORE"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:gravity="center"
            android:drawableEnd="@drawable/ic_arrow"
            android:drawablePadding="8dp"
            android:background="@drawable/boton_1"/>

        <Button
            android:id="@+id/btnBotones"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="LEARN MORE"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:gravity="center"
            android:drawableEnd="@drawable/ic_arrow"
            android:drawablePadding="8dp"
            android:background="@drawable/boton_2"/>

        <Button
            android:id="@+id/btnSeleccion"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="BOOK NOW"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:gravity="center"
            android:drawableEnd="@drawable/ic_arrow"
            android:drawablePadding="8dp"
            android:background="@drawable/boton_3"/>

        <Button
            android:id="@+id/btnListas"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="APPLY NOW"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:gravity="center"
            android:drawableEnd="@drawable/ic_arrow"
            android:drawablePadding="8dp"
            android:background="@drawable/boton_4"/>

        <Button
            android:id="@+id/btnInfo"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="MORE INFO"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:gravity="center"
            android:drawableEnd="@drawable/ic_arrow"
            android:drawablePadding="8dp"
            android:background="@drawable/boton_5"/>


    </LinearLayout>



</LinearLayout>